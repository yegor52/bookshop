 *   orderId, status, deliveryDate, totalAmount,
 *   items: [{ id, bookId, title, author, price, quantity, totalPrice }]
 * }
 */
export const getCart = async () => {
    try {
        const response = await api.get('/api/client/cart')
        return response.data
    } catch (error) {
